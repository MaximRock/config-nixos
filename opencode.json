{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["promt-help.md", "AGENTS.md"],
  "lsp": true,
  "mcp": {
    "dotfiles-helper": {
      "type": "local",
      "command": ["mcp-dotfiles-helper"],
      "environment": {
        "DOTFILES_REPO": "/home/max/.dotfiles"
      }
    },
    "rime": {
      "type": "local",
      "command": ["rime", "stdio"],
      "enabled": true
    }
  }
}
